{
    "name": "siviwe191/nova-tabs",
    "description": "An updated Laravel Nova tool to create tabs in nova work 5 and added ability to add fontawesome icons and change entire background of tab",
    "keywords": [
        "laravel",
        "nova"
    ],
    "authors": [
        {
            "name": "Siviwe191",
            "email": "svellem51@gmail.com"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/nova": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "ShuvroRoy\\NovaTabs\\": "src/",
            "ShuvroRoy\\NovaTabs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShuvroRoy\\NovaTabs\\TabsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "build": [
            "npm --prefix './vendor/laravel/nova/' ci",
            "npm ci",
            "TAILWIND_MODE=build npm run prod"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
